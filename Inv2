<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Veme 1 - Cali Open World</title>
    <style>
        body { margin:0; overflow:hidden; background:#222; font-family: sans-serif; }
        #ui { position:fixed; top:10px; left:10px; color:#fff; pointer-events:none; }
        .title { font-size: 24px; font-weight: bold; color: #fbbf24; }
        #controls { position:fixed; bottom:20px; width:100%; display:flex; justify-content:center; gap:10px; }
        button { padding:20px; border-radius:50%; border:none; background:rgba(255,255,255,0.9); font-size:18px; touch-action: manipulation; }
    </style>
</head>
<body>

    <div id="ui">
        <div class="title">VEME 1</div>
        <div id="mode-text">MODE: DRIVING</div>
        <div id="stats">Money: $1000 | HP: 100</div>
    </div>

    <div id="controls">
        <button onpointerdown="input.fwd=true" onpointerup="input.fwd=false">⬆</button>
        <button onclick="toggleMode()">🚗/🚶</button>
        <button onclick="buyWeapon()">🔫</button>
        <button onclick="attack()">🔥</button>
    </div>

    <script src="https://unpkg.com/three@0.160.0/build/three.min.js"></script>
    <script>
        // --- 1. CORE ENGINE ---
        const scene = new THREE.Scene(); scene.background = new THREE.Color(0x87CEEB);
        const camera = new THREE.PerspectiveCamera(75, innerWidth/innerHeight, 0.1, 1000);
        const renderer = new THREE.WebGLRenderer({antialias:true});
        renderer.setSize(innerWidth, innerHeight);
        document.body.appendChild(renderer.domElement);

        // --- 2. GAME OBJECTS ---
        const car = new THREE.Mesh(new THREE.BoxGeometry(1, 0.5, 2), new THREE.MeshStandardMaterial({color: 0xff0000}));
        const player = new THREE.Mesh(new THREE.BoxGeometry(0.5, 1, 0.5), new THREE.MeshStandardMaterial({color: 0x00ff00}));
        const heli = new THREE.Mesh(new THREE.ConeGeometry(0.5, 2, 8), new THREE.MeshStandardMaterial({color: 0x555555}));
        heli.position.set(0, 15, 0);
        scene.add(car, player, heli);

        // --- 3. STATE MANAGER ---
        let mode = 'DRIVING', input = {fwd:false};

        function toggleMode() {
            mode = (mode === 'DRIVING') ? 'WALKING' : 'DRIVING';
            document.getElementById('mode-text').innerText = "MODE: " + mode;
        }

        function buyWeapon() { alert("Đã vào shop súng!"); }
        function attack() { alert("Veme 1 đang tấn công!"); }

        // --- 4. GAME LOOP (Hệ thống điều khiển) ---
        function animate() {
            requestAnimationFrame(animate);

            // Helicopter AI bám đuổi
            heli.position.x += (player.position.x - heli.position.x) * 0.01;
            heli.position.z += (player.position.z - heli.position.z) * 0.01;

            // Di chuyển
            if(mode === 'DRIVING') {
                if(input.fwd) {
                    car.position.x += Math.sin(car.rotation.y) * 0.1;
                    car.position.z += Math.cos(car.rotation.y) * 0.1;
                }
                camera.position.set(car.position.x, car.position.y + 5, car.position.z + 8);
                camera.lookAt(car.position);
            } else {
                if(input.fwd) {
                    player.position.x += Math.sin(player.rotation.y) * 0.05;
                    player.position.z += Math.cos(player.rotation.y) * 0.05;
                }
                camera.position.set(player.position.x, player.position.y + 3, player.position.z + 5);
                camera.lookAt(player.position);
            }

            renderer.render(scene, camera);
        }
        animate();
    </script>
</body>
</html>
