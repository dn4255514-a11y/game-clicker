<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Clicker Season EVENT PRO</title>
    <style>
        body { background-color: #0f172a; color: #f8fafc; text-align: center; font-family: sans-serif; padding: 20px; }
        .container { max-width: 500px; margin: auto; background: #1e293b; padding: 30px; border-radius: 20px; }
        #money { font-size: 50px; font-weight: bold; color: #fbbf24; }
        button { padding: 15px; width: 100%; cursor: pointer; background: #38bdf8; border: none; border-radius: 10px; color: white; font-weight: bold; margin-top: 10px; }
        input { padding: 10px; width: 80%; border-radius: 5px; border: none; margin-top: 20px; }
    </style>
</head>
<body>

<div class="container">
    <h1>🔥 CLICKER PRO</h1>
    <div id="money">0 $</div>
    <button onclick="clickMoney()">⛏️ ĐÀO TIỀN</button>

    <div class="secret-area">
        <h3>🔓 Nhập mã (12345678) mở nhạc:</h3>
        <input type="password" id="secretCode" placeholder="Nhập mã...">
        <button onclick="checkCode()" style="background: #22c55e;">PHÁT NHẠC KHÔNG BẢN QUYỀN</button>
        <p id="musicStatus"></p>
        
        <audio id="myAudio" src="https://www.soundhelix.com/examples/mp3/SoundHelix-Song-2.mp3"></audio>
    </div>
</div>

<script>
    let money = 0;
    function clickMoney() {
        money += 1;
        document.getElementById("money").innerText = money + " $";
    }

    function checkCode() {
        let code = document.getElementById("secretCode").value;
        let audio = document.getElementById("myAudio");
        if (code === "12345678") {
            audio.play();
            document.getElementById("musicStatus").innerText = "🎵 Đang phát: Nhạc nền miễn phí!";
        } else {
            alert("Mã không đúng!");
        }
    }
</script>

</body>
</html>
